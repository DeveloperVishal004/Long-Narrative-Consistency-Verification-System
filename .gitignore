# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# ── Test / type / lint caches ────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ── Virtual environments ─────────────────────────────────
.venv/
venv/
env/

# ── Secrets / environment ────────────────────────────────
# Never commit the real .env. The committed template is .env.example.
.env
.env.*
!.env.example

# ── Editor / IDE / OS ────────────────────────────────────
.vscode/
.idea/
.DS_Store

# ── Agent / harness local state ──────────────────────────
.claude/

# ── Logs ─────────────────────────────────────────────────
*.log

# ── Model checkpoints / vector stores ────────────────────
*.pt
*.pth
*.ckpt
*.bin
chroma_db/
chromadb/
.chroma/
*.sqlite
*.sqlite3

# ── Notebook checkpoints ─────────────────────────────────
.ipynb_checkpoints/

# ── Generated run artifacts & caches (results/) ──────────
# Everything under results/ is generated by the pipeline and is
# reproducible from source + the public datasets. Only the curated,
# human-readable report artifacts are committed (negated below):
#   - LLM completion / extraction / NLI caches (results/*cache*.jsonl)
#   - graph-impact study checkpoints (results/graph_impact_*)
#   - prediction dumps (results/predictions_*.jsonl, multi-MB)
#   - audit / diagnostic dumps (results/*_audit_*.json, *_dump.json, etc.)
results/*
!results/evaluation_report.md
!results/long_narrative_validation_tier1_20260624T185656Z.md
